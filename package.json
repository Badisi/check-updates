{
    "name": "@badisi/check-updates",
    "version": "1.0.1",
    "description": "An interactive CLI to scan, visualize and upgrade NPM dependencies — locally or globally.",
    "homepage": "https://github.com/Badisi/check-updates",
    "license": "MIT",
    "author": {
        "name": "Badisi"
    },
    "type": "module",
    "main": "./index.mjs",
    "module": "./index.mjs",
    "types": "./index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./index.d.mts",
                "default": "./index.mjs"
            }
        },
        "./package.json": "./package.json"
    },
    "bin": {
        "check-updates": "bin/check-updates",
        "cu": "bin/check-updates"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Badisi/check-updates.git"
    },
    "keywords": [
        "npm",
        "check",
        "updates",
        "latest",
        "current",
        "next",
        "outdated",
        "version",
        "pkg",
        "package",
        "package-json",
        "dependencies",
        "module"
    ],
    "scripts": {
        "check-updates": "tsx src/index.ts . -i",
        "start": "tsx src/index.ts",
        "lint": "eslint .",
        "test": "vitest",
        "test:ci": "vitest run",
        "typecheck": "tsc --noEmit",
        "build": "tsc && tsdown",
        "release": "npm publish ./dist --access public"
    },
    "engines": {
        "node": ">= 20.12.0"
    },
    "dependencies": {
        "@badisi/latest-version": "^9.0.0",
        "@clack/prompts": "^1.7.0",
        "enquirer": "^2.4.1",
        "fast-glob": "^3.3.3",
        "package-json": "^10.0.1",
        "semver": "^7.8.5"
    },
    "devDependencies": {
        "@hug/eslint-config": "^26.0.0",
        "@types/node": "^26.1.1",
        "@types/semver": "^7.7.1",
        "tsdown": "^0.22.4",
        "tsx": "^4.23.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.10"
    },
    "allowScripts": {
        "esbuild@0.28.1": true,
        "fsevents@2.3.3": true,
        "@hug/eslint-config@26.0.0": true
    }
}
